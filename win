$OutputBox = $Window.FindName("OutputBox")

# Helper Function to Update Console and GUI
function Write-Log ($Message) {
    $Timestamp = Get-Date -Format "HH:mm:ss"
    $OutputBox.AppendText("[$Timestamp] $Message`r`n")
    $OutputBox.ScrollToEnd()
    [System.Windows.Threading.Dispatcher]::CurrentDispatcher.Invoke([System.Windows.Threading.DispatcherPriority]::Background, [Action]{})
}

# --- FUNCTIONS ---

function Run-ScriptOrExe ($Name, $Url, $Extension) {
    Write-Log "Initializing $Name deployment..."
    $StatusText.Text = "Working on $Name..."; $StatusText.Foreground = "#FFFF00"
    $TempPath = Join-Path $env:TEMP "$Name$Extension"
    try {
        Write-Log "Downloading from cloud source..."
        Invoke-WebRequest -Uri $Url -OutFile $TempPath -UseBasicParsing
        Write-Log "Launching process. Please wait..."
        Start-Process -FilePath $TempPath -Wait
        Remove-Item -Path $TempPath -Force -ErrorAction SilentlyContinue
        Write-Log "SUCCESS: $Name completed."
        $StatusText.Text = "Ready."; $StatusText.Foreground = "#00FF00"
    } catch { 
        Write-Log "CRITICAL ERROR: $($_.Exception.Message)"
        $StatusText.Text = "Error."; $StatusText.Foreground = "Red" 
    }
}

function Run-Zip ($Name, $Url, $TargetFile) {
    Write-Log "Preparing ZIP extraction for $Name..."
    $StatusText.Text = "Extracting $Name..."; $StatusText.Foreground = "#FFFF00"
    $ZipPath = Join-Path $env:TEMP "$Name.zip"
    $ExtractPath = Join-Path $env:TEMP "CA_$Name"
    try {
        Write-Log "Downloading ZIP package..."
        Invoke-WebRequest -Uri $Url -OutFile $ZipPath -UseBasicParsing
        Write-Log "Unzipping to temp directory..."
        if (Test-Path $ExtractPath) { Remove-Item $ExtractPath -Recurse -Force }
        Expand-Archive -Path $ZipPath -DestinationPath $ExtractPath -Force
        $Exe = Get-ChildItem -Path $ExtractPath -Filter $TargetFile -Recurse | Select-Object -First 1
        if ($Exe) {
            Write-Log "Executing core file: $($Exe.Name)..."
            Start-Process -FilePath $Exe.FullName -Wait
            Write-Log "SUCCESS: Execution finished."
        }
        Remove-Item -Path $ZipPath -Force
        Remove-Item -Path $ExtractPath -Recurse -Force
        $StatusText.Text = "Ready."; $StatusText.Foreground = "#00FF00"
    } catch { 
        Write-Log "ZIP ERROR: $($_.Exception.Message)"
        $StatusText.Text = "Error."; $StatusText.Foreground = "Red" 
    }
}

# --- BUTTON BINDINGS ---

# Direct Activation (Replaces the external .bat to avoid multiple windows)
$Window.FindName("BtnWinTools").Add_Click({
    Write-Log "Starting Microsoft Activation Scripts (MAS)..."
    $StatusText.Text = "Activating..."; $StatusText.Foreground = "#FFFF00"
    try {
        # Runs the core activation command directly within the current admin session
        powershell -NoProfile -ExecutionPolicy Bypass -Command "irm https://get.activated.win | iex"
        Write-Log "MAS operation completed successfully."
        $StatusText.Text = "Ready."; $StatusText.Foreground = "#00FF00"
    } catch { Write-Log "Activation failed: $($_.Exception.Message)" }
})

$Window.FindName("BtnOfficeAct").Add_Click({ Run-ScriptOrExe -Name "OfficeAct" -Url $Links.Office16 -Extension ".exe" })
$Window.FindName("BtnScrubber").Add_Click({ Run-Zip -Name "Scrubber" -Url $Links.Scrubber -TargetFile "OfficeScrubber.cmd" })
$Window.FindName("BtnGenP").Add_Click({ Run-Zip -Name "GenP" -Url $Links.GenP -TargetFile "RunMe.exe" })
$Window.FindName("BtnWinrar").Add_Click({ Run-Zip -Name "Winrar" -Url $Links.Winrar -TargetFile "Winrar.cmd" })
$Window.FindName("BtnUpdate").Add_Click({ Run-ScriptOrExe -Name "SysUpdate" -Url $Links.UpdateSystem -Extension ".bat" })

$Window.FindName("BtnSFC").Add_Click({ 
    Write-Log "Starting System File Checker (SFC Scan)..."
    $StatusText.Text = "SFC Scanning..."
