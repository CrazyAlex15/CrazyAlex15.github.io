        WindowStartupLocation="CenterScreen" Background="#0F0F0F" 
        FontFamily="Segoe UI" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1A1A1A" Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">
                <TextBlock Text="CRAZY ALEX" Foreground="#00FFFF" FontSize="26" FontWeight="Black" Margin="0,15,0,0"/>
                <TextBlock Text="CLOUD SUITE v11" Foreground="#F48FB1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,40"/>
                <TextBlock Text="STATUS:" Foreground="#777777" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock Name="StatusText" Text="Ready." Foreground="#00FFFF" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
