function Write-Log ($Message) {
    $Timestamp = Get-Date -Format "HH:mm:ss"
    if ($OutputBox) {
        $OutputBox.AppendText("[$Timestamp] $Message`r`n")
        $OutputBox.ScrollToEnd()
    }
    [System.Windows.Threading.Dispatcher]::CurrentDispatcher.Invoke([System.Windows.Threading.DispatcherPriority]::Background, [Action]{})
}

# --- FUNCTIONS ---
function Run-ScriptOrExe ($Name, $Url, $Extension) {
    $StatusText.Text = "DOWNLOADING..."; Write-Log "Connecting to cloud node for $Name..."
    $TempPath = Join-Path $env:TEMP "$Name$Extension"
    try {
        Invoke-WebRequest -Uri $Url -OutFile $TempPath -UseBasicParsing
        Write-Log "Executing $Name..."
        Start-Process -FilePath $TempPath -Wait
        Write-Log "Process $Name terminated successfully."
    } catch { Write-Log "ERROR: $($_.Exception.Message)" }
    $StatusText.Text = "ONLINE & READY"
}

function Run-Zip ($Name, $Url, $TargetFile) {
    $StatusText.Text = "DOWNLOADING..."; Write-Log "Fetching $Name Package..."
    $ZipPath = Join-Path $env:TEMP "$Name.zip"
    $ExtractPath = Join-Path $env:TEMP "CA_$Name"
    
    try {
        # THE GOOGLE DRIVE 5GB BYPASS
        if ($Url -like "*drive.google.com*") {
            Write-Log "Bypassing Google Drive Virus Scan Protocol..."
            $FileId = $Url.Split("id=")[1].Split("&")[0]
            $BaseUrl = "https://drive.google.com/uc?export=download&id=$FileId"
            
            $WebSession = New-Object Microsoft.PowerShell.Commands.WebRequestSession
            $Response = Invoke-WebRequest -Uri $BaseUrl -WebSession $WebSession -UseBasicParsing
            
            # Ψάχνουμε το κρυφό 'confirm=' token που ζητάει η Google
            if ($Response.Content -match 'confirm=([a-zA-Z0-9\-_]+)') {
                $Token = $Matches[1]
                Write-Log "Token Acquired ($Token). Commencing heavy data transfer (5GB)..."
                $FinalUrl = "https://drive.google.com/uc?export=download&confirm=$Token&id=$FileId"
                Invoke-WebRequest -Uri $FinalUrl -OutFile $ZipPath -WebSession $WebSession -UseBasicParsing
            } else {
                Write-Log "Token not found. Attempting direct connection..."
                Invoke-WebRequest -Uri $BaseUrl -OutFile $ZipPath -WebSession $WebSession -UseBasicParsing
            }
        } else {
            Invoke-WebRequest -Uri $Url -OutFile $ZipPath -UseBasicParsing
        }

        Write-Log "Download complete. Extracting package data..."
        if (Test-Path $ExtractPath) { Remove-Item $ExtractPath -Recurse -Force }
        Expand-Archive -Path $ZipPath -DestinationPath $ExtractPath -Force
        
        $Exe = Get-ChildItem $ExtractPath -Filter $TargetFile -Recurse | Select -First 1
        if ($Exe) {
            Write-Log "Running payload: $($Exe.Name)..."
            Start-Process $Exe.FullName -Wait
            Write-Log "Payload executed successfully."
        } else {
            Write-Log "ERROR: Target file '$TargetFile' not found in package!"
        }
    } catch { Write-Log "ERROR: $($_.Exception.Message)" }
    
    # Cleanup (Optional: If you want to keep the 5GB file, put a # before the next line)
    Remove-Item $ZipPath -Force -ErrorAction SilentlyContinue
    $StatusText.Text = "ONLINE & READY"
}

