            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="ACTIVATION HUB" Foreground="#F48FB1" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                <WrapPanel>
                    <Button Name="BtnWinOfficeTools" Content="Win/Office Activation" Width="200" Height="45" Margin="0,0,10,15" Background="#F48FB1" Foreground="#000000" BorderThickness="0" FontWeight="Bold"/>
                    <Button Name="BtnOfficeAct" Content="Activate Office 16-19" Width="200" Height="45" Margin="0,0,10,15" Background="#9C27B0" Foreground="White" BorderThickness="0"/>
                    <Button Name="BtnScrubber" Content="Office Scrubber" Width="200" Height="45" Margin="0,0,10,15" Background="#9C27B0" Foreground="White" BorderThickness="0"/>
                    <Button Name="BtnGenP" Content="GenP-main" Width="200" Height="45" Margin="0,0,10,15" Background="#9C27B0" Foreground="White" BorderThickness="0"/>
                    <Button Name="BtnWinrar" Content="Winrar" Width="200" Height="45" Margin="0,0,10,15" Background="#9C27B0" Foreground="White" BorderThickness="0"/>
                    <Button Name="BtnUpdate" Content="System Update" Width="200" Height="45" Margin="0,0,10,15" Background="#9C27B0" Foreground="White" BorderThickness="0"/>
                </WrapPanel>

                <TextBlock Text="QUICK MAINTENANCE" Foreground="#00FFFF" FontSize="18" FontWeight="Bold" Margin="0,5,0,15"/>
                <WrapPanel>
                    <Button Name="BtnSFC" Content="SFC Scan" Width="130" Height="40" Margin="0,0,10,10" Background="#A5D6A7" Foreground="Black" BorderThickness="0" FontWeight="SemiBold"/>
                    <Button Name="BtnWifi" Content="Fix Network" Width="130" Height="40" Margin="0,0,10,10" Background="#A5D6A7" Foreground="Black" BorderThickness="0" FontWeight="SemiBold"/>
                    <Button Name="BtnKey" Content="Show Key" Width="130" Height="40" Margin="0,0,10,10" Background="#A5D6A7" Foreground="Black" BorderThickness="0" FontWeight="SemiBold"/>
