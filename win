            <GroupBox Header="Live Console Output" Grid.Row="1" Foreground="#00FFFF" BorderBrush="#F48FB1" Margin="0,10,0,0">
                <TextBox Name="OutputBox" Background="#050505" Foreground="#00FF00" 
